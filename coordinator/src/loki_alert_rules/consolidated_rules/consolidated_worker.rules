groups:
- name: VtvwAtuq4S2kV2DdoLK3_fb6875be_worker_high_log_volume_rules
  rules:
  - alert: HighLogVolume
    annotations:
      summary: Log rate is too high!
    expr: 'count_over_time(({job=~".+"})[30s]) > 100

      '
    labels:
      juju_application: worker
      juju_charm: loki
      juju_model: VtvwAtuq4S2kV2DdoLK3
      juju_model_uuid: fb6875be-1d8f-437a-a84a-3a3054a5a5f9
      severity: high
